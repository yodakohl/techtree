{
  "name": "techtree",
  "version": "1.0.0",
  "description": "Source-backed human technology dependency graph for exploring prerequisites, unlocks, and future roadmap fields.",
  "main": "server.js",
  "scripts": {
    "coverage": "node scripts/coverage-report.js",
    "build:public": "node scripts/generate-public-site.js",
    "check:public": "node scripts/check-public-site.js",
    "agent:brief": "node scripts/agent-brief.js",
    "agent:next": "node scripts/agent-next.js",
    "agent:check": "node scripts/agent-check-plan.js",
    "accuracy:risks": "node scripts/generate-quality-snapshot.js --silent && node scripts/accuracy-risk-report.js",
    "quality:snapshot": "node scripts/generate-quality-snapshot.js",
    "metrics:check": "node scripts/check-published-metrics.js",
    "quality:placeholder-dates": "node scripts/source-checked-placeholder-report.js",
    "quality:source-checked-sample": "node scripts/source-checked-audit-sample.js",
    "quality:source-fit": "node scripts/audit-random-source-fit.js",
    "quality:queue": "node scripts/source-quality-queue.js",
    "quality:field:crispr": "node scripts/generate-field-quality-snapshot.js",
    "trust:audit": "node scripts/audit-trust-levels.js",
    "audit:crispr": "node scripts/audit-crispr-edge-quality.js",
    "edge-packet": "node scripts/edge-review-packet.js",
    "node-packet": "node scripts/node-scope-packet.js",
    "node-snapshot": "node scripts/node-scope-snapshot.js",
    "node-snapshot-diff": "node scripts/compare-node-scope-snapshots.js",
    "graph-invariants": "node scripts/check-graph-invariants.js",
    "invariant-coverage": "node scripts/audit-invariant-coverage.js",
    "edge-receipts": "node scripts/check-edge-change-receipts.js",
    "source-urls": "node scripts/audit-source-urls.js",
    "temporal": "node scripts/audit-temporal-consistency.js",
    "quality": "node scripts/audit-data-quality.js && npm run edge-receipts && npm run graph-invariants && npm run invariant-coverage && npm run trust:audit && node scripts/source-checked-placeholder-report.js --check && node scripts/audit-random-source-fit.js --check && node scripts/generate-quality-snapshot.js --check && node scripts/generate-field-quality-snapshot.js --check && npm run metrics:check && npm run check:public",
    "test": "node scripts/validate-data.js && npm run temporal",
    "start": "node server.js"
  },
  "keywords": [
    "technology-tree",
    "tech-tree",
    "technology-roadmap",
    "dependency-map",
    "knowledge-graph",
    "dependency-graph",
    "open-data",
