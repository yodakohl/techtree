{
  "name": "techtree",
  "version": "1.0.0",
  "description": "Source-backed human technology dependency graph for exploring prerequisites, unlocks, and future roadmap fields.",
  "main": "server.js",
  "scripts": {
    "coverage": "node scripts/coverage-report.js",
    "accuracy:risks": "node scripts/generate-quality-snapshot.js --silent && node scripts/accuracy-risk-report.js",
    "quality:snapshot": "node scripts/generate-quality-snapshot.js",
    "audit:crispr": "node scripts/audit-crispr-edge-quality.js",
    "edge-packet": "node scripts/edge-review-packet.js",
    "node-packet": "node scripts/node-scope-packet.js",
    "node-snapshot": "node scripts/node-scope-snapshot.js",
    "node-snapshot-diff": "node scripts/compare-node-scope-snapshots.js",
    "graph-invariants": "node scripts/check-graph-invariants.js",
    "invariant-coverage": "node scripts/audit-invariant-coverage.js",
    "edge-receipts": "node scripts/check-edge-change-receipts.js",
    "source-urls": "node scripts/audit-source-urls.js",
    "temporal": "node scripts/audit-temporal-consistency.js",
    "quality": "node scripts/audit-data-quality.js && npm run edge-receipts && npm run graph-invariants && npm run invariant-coverage && node scripts/generate-quality-snapshot.js --check",
    "test": "node scripts/validate-data.js && npm run temporal",
    "start": "node server.js"
  },
  "keywords": [
    "technology-tree",
    "tech-tree",
    "technology-roadmap",
    "dependency-map",
    "knowledge-graph",
    "dependency-graph",
    "open-data",
    "research-tool",
    "history-of-technology",
    "human-technology",
    "invention-timeline",
    "interactive-graph",
    "science-and-technology",
    "crispr",
    "semiconductors",
    "artificial-intelligence",
    "energy-systems",
    "spaceflight",
    "robotics",
    "climate-tech",
    "agriculture-technology",
    "cybersecurity",
    "cryptography",
    "transportation",
    "logistics",
    "materials-science",
    "telecommunications",
    "networking",
    "water-technology",
    "sanitation",
    "wastewater",
    "drug-discovery",
    "pharmaceuticals",
    "pharmacology",
    "clinical-trials"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yodakohl/techtree.git"
  },
  "bugs": {
    "url": "https://github.com/yodakohl/techtree/issues"
